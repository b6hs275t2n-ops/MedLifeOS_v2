<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Settings | MedLife OS</title>

<link rel="stylesheet" href="style.css">
<script src="app.js"></script>

</head>

<body>

<div class="sidebar">

<div class="logo">🩺 MedLife OS</div>

<ul class="nav">
<li><a href="index.html">🏠 Dashboard</a></li>
<li><a href="study.html">📚 Study Planner</a></li>
<li><a href="goals.html">🎯 Goals</a></li>
<li><a href="notes.html">📝 Notes</a></li>
<li><a href="analytics.html">📊 Analytics</a></li>
<li><a href="settings.html" class="active">⚙️ Settings</a></li>
</ul>

</div>

<div class="main">

<h1>⚙️ Settings</h1>

<br>

<div class="card">

<h2>Appearance</h2>

<br>

<button id="themeBtn" onclick="toggleTheme()">
🌙 Toggle Dark / Light Mode
</button>

</div>

<br>

<div class="card">

<h2>Data Management</h2>

<br>

<button id="themeBtn" onclick="clearGoals()">
🎯 Clear All Goals
</button>

<br><br>

<button id="themeBtn" onclick="clearNotes()">
📝 Clear All Notes
</button>

<br><br>

<button id="themeBtn" onclick="resetApp()">
🗑 Reset Entire App
</button>

</div>

<br>

<div class="card">

<h2>About MedLife OS</h2>

<br>

<p>
Version: 2.0
</p>

<br>

<p>
Built for medical students to manage study plans,
notes, goals, analytics and NEET PG preparation.
</p>

</div>

</div>

<script>

function clearGoals(){

localStorage.removeItem(
"medlife_goals"
);

alert(
"All goals deleted successfully."
);

}

function clearNotes(){

localStorage.removeItem(
"medlife_notes"
);

alert(
"All notes deleted successfully."
);

}

function resetApp(){

const confirmReset =
confirm(
"Delete all MedLife OS data?"
);

if(confirmReset){

localStorage.clear();

alert(
"App reset successfully."
);

location.reload();

}

}

</script>

</body>
</html>
